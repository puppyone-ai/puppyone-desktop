{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020", "ES2021.Intl"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@puppyone/localization": ["packages/localization/src/index.ts"],
      "@puppyone/localization/*": ["packages/localization/src/*"],
      "@puppyone/shared-ui": ["packages/shared-ui/src/index.ts"],
      "lucide-react": ["node_modules/lucide-react/dist/lucide-react.d.ts"],
      "react": ["node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["node_modules/@types/react/jsx-runtime.d.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src", "shared/agent-contract/**/*.ts", "packages/localization/src", "packages/shared-ui/src"],
  "references": []
}
