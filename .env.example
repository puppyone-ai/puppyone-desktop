# Required Cloud endpoints. Configure these per environment; application code
# does not carry fallback URLs.
VITE_DESKTOP_CLOUD_API_URL=https://api.puppyone.ai/api/v1
VITE_DESKTOP_CLOUD_WEB_URL=https://app.puppyone.ai

# Required by `npm run dev`. For local Cloud development, point the API/Web
# values above at localhost and set the sibling Cloud repository path.
PUPPYONE_DESKTOP_RENDERER_URL=http://127.0.0.1:5173
PUPPYONE_CLOUD_DEV_ROOT=../puppyone

# Optional Electron updater override for local/internal testing.
# PUPPYONE_DESKTOP_UPDATE_URL=https://updates.puppyone.ai/desktop/stable/mac
# PUPPYONE_DESKTOP_UPDATE_CHANNEL=stable

# Enable verbose updater logs in Electron.
# PUPPYONE_DESKTOP_UPDATE_LOG_CONSOLE=1
